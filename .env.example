# Supabase — copy to .env.local and fill from your project's API settings.
# (Project → Settings → API)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# The kit this deployment sells access to.
VITE_KIT_ID=stage-b-grade2

# Grow checkout page URL on the marketing site (the paywall links here).
VITE_CHECKOUT_URL=https://your-marketing-site/checkout

# Deploy base path. Leave unset for gh-pages (defaults to /gifted-exam-practice/).
# On Vercel set VITE_DEPLOY_BASE=/
# VITE_DEPLOY_BASE=/
